c{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "labels": ["automerge"],
  "ignorePaths": ["**/autogenerated-**"],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/postgres/"],
      "matchUpdateTypes": ["major"],
      "labels": []
    }
  ],
  "postUpgradeTasks": {
    "commands": [
      "cd infrastructure && terraform init -upgrade",
      "cd service && terraform init -upgrade"
    ],
    "filePatterns": [".terraform.lock.hcl"],
    "excludeCommitPaths": []
  }
}
